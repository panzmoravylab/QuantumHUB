# MetaTrader 5 — cesta se hleda automaticky (MT5_PATH neni potreba)

# MT5 account credentials (optional if terminal is already logged in)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Expected account validation (login number, not balance)
MT5_EXPECTED_ACCOUNT=
MT5_EXPECTED_COMPANY=MetaQuotes

# Header chip display (prop account size — DD % se počítá z této hodnoty)
STARTING_BALANCE=25000

# Primary trading symbol
SYMBOL=XAUUSD

# DXY symbol for correlation gauge
DXY_SYMBOL=USDX

# --- Safety / prop guard ---
AUTO_KILL_ON_CRITICAL=false
KILL_CONFIRM_CLICKS=2
KILL_CONFIRM_SECONDS=3
SL_MODE=atr
SL_ATR_MULTIPLIER=1.5
SL_POINTS=0
SL_PCT=0
SLIPPAGE_WARN_POINTS=5

# --- HUD zobrazení ---
# main = široký 3-sloupcový layout (default) | portrait = vertikální stack pro 1080×1920
# HUD_LAYOUT=main
# HUD_LAYOUT=portrait
# trade = Obchod (default) | prep = Příprava | detail = Detail
HUD_TIER=trade
# HUD_UI_LANG=CZ
# HUD_UI_LANG=EN

# --- TEST mode (Spustit_Quantum_HUD_TEST.bat) ---
# HUD_MODE=test
# HUD_UI_LANG=EN
# TEST_SNAPSHOT=test_data/default_snapshot.json
# TEST_M1_BAR_SECONDS=30
# TEST_REPLAY_SPEED=1
# TEST_REPLAY_LOOP=true
# TEST_SCENARIO=healthy

# --- Tier 5 (připraveno, default off) ---
TRADINGVIEW_ZONES_PATH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ORDER_ENTRY_ENABLED=false
