# Volitelna konfigurace pro Spustit_Quantum_HUD_TEST.bat
# Zkopirujte na .env.test a upravte

# healthy | near_limit | critical
TEST_SCENARIO=healthy

# Sekund na 1 replay M1 svicku (realny cas). 30 = 2x rychleji nez live M1 (60s).
TEST_M1_BAR_SECONDS=30

# Volitelny nasobitel tempa (1 = bez zmeny)
TEST_REPLAY_SPEED=1

# true = po dohrani znovu od start_index
TEST_REPLAY_LOOP=true

# Vlastni snapshot (relativni k projektu)
TEST_SNAPSHOT=test_data/default_snapshot.json

# Hlavicka dashboardu
STARTING_BALANCE=100000
